generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["core_platform", "tenant_data"]
}

model Tenant {
  id            String               @id @default(uuid()) @db.Uuid
  name          String
  subdomain     String               @unique
  customDomain  String?              @unique @map("custom_domain")
  industryType  String               @map("industry_type")
  currency      String               @default("USD")
  status        String               @default("ACTIVE")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  subscription  TenantSubscription[]
  auditLogs     AuditLog[]
  customers     Customer[]
  expenses      Expense[]
  balances      InventoryBalance[]
  invitations   Invitation[]
  items         InvoiceItem[]
  invoices      Invoice[]
  payments      Payment[]
  variants      ProductVariant[]
  products      Product[]
  roles         Role[]
  tenantModules TenantModule[]
  sessions      UserSession[]
  users         User[]
  warehouses    Warehouse[]
  templates        TenantTemplate[]
  dashboardWidgets TenantDashboardWidget[]
  workflowStates   TenantWorkflowState[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  purchaseItems    PurchaseOrderItem[]
  vehicles         Vehicle[]
  projects         Project[]
  tasks            Task[]
  productionOrders ProductionOrder[]

  @@map("tenants")
  @@schema("core_platform")
}

model SubscriptionPlan {
  id                   String               @id @default(uuid()) @db.Uuid
  name                 String               @unique
  priceMonthly         Decimal              @map("price_monthly") @db.Decimal(10, 2)
  priceYearly          Decimal              @map("price_yearly") @db.Decimal(10, 2)
  stripePriceIdMonthly String?              @map("stripe_price_id_monthly")
  stripePriceIdYearly  String?              @map("stripe_price_id_yearly")
  maxUsers             Int                  @map("max_users")
  maxWarehouses        Int                  @map("max_warehouses")
  maxProducts          Int                  @map("max_products")
  features             Json
  createdAt            DateTime             @default(now()) @map("created_at")
  subscriptions        TenantSubscription[]

  @@map("subscription_plans")
  @@schema("core_platform")
}

model TenantSubscription {
  id                   String           @id @default(uuid()) @db.Uuid
  tenantId             String           @map("tenant_id") @db.Uuid
  planId               String           @map("plan_id") @db.Uuid
  stripeSubscriptionId String?          @unique @map("stripe_subscription_id")
  status               String
  billingCycle         String           @map("billing_cycle")
  trialStart           DateTime?        @map("trial_start")
  trialEnd             DateTime?        @map("trial_end")
  currentPeriodStart   DateTime         @map("current_period_start")
  currentPeriodEnd     DateTime         @map("current_period_end")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  plan                 SubscriptionPlan @relation(fields: [planId], references: [id])
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_subscriptions")
  @@schema("core_platform")
}

model User {
  id                 String        @id @default(uuid()) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  firstName          String        @map("first_name")
  lastName           String        @map("last_name")
  email              String        @unique
  passwordHash       String        @map("password_hash")
  twoFactorSecret    String?       @map("two_factor_secret")
  isTwoFactorEnabled Boolean       @default(false) @map("is_two_factor_enabled")
  phoneNumber        String?       @map("phone_number")
  isEmailVerified    Boolean       @default(false) @map("is_email_verified")
  status             String        @default("ACTIVE")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  auditLogs          AuditLog[]
  roles              UserRole[]
  sessions           UserSession[]
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dashboardWidgets   TenantDashboardWidget[]

  @@map("users")
  @@schema("tenant_data")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  name        String
  description String?
  isCustom    Boolean          @default(false) @map("is_custom")
  createdAt   DateTime         @default(now()) @map("created_at")
  permissions RolePermission[]
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       UserRole[]

  @@unique([tenantId, name])
  @@map("roles")
  @@schema("tenant_data")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  module      String
  action      String
  description String?
  roles       RolePermission[]

  @@unique([module, action])
  @@map("permissions")
  @@schema("tenant_data")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("tenant_data")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("tenant_data")
}

model Customer {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  name               String
  email              String?
  phone              String?
  taxNumber          String?   @map("tax_number")
  creditLimit        Decimal   @default(0.00) @map("credit_limit") @db.Decimal(12, 2)
  outstandingBalance Decimal   @default(0.00) @map("outstanding_balance") @db.Decimal(12, 2)
  shippingAddress    String?   @map("shipping_address")
  billingAddress     String?   @map("billing_address")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices           Invoice[]
  vehicles           Vehicle[]
  projects           Project[]

  @@index([tenantId, phone])
  @@index([tenantId, name])
  @@map("customers")
  @@schema("tenant_data")
}

model Product {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  categoryId      String?          @map("category_id") @db.Uuid
  brand           String?
  name            String
  description     String?
  isVariantParent Boolean          @default(false) @map("is_variant_parent")
  createdAt       DateTime         @default(now()) @map("created_at")
  variants        ProductVariant[]
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("products")
  @@schema("tenant_data")
}

model ProductVariant {
  id            String              @id @default(uuid()) @db.Uuid
  tenantId      String              @map("tenant_id") @db.Uuid
  productId     String              @map("product_id") @db.Uuid
  sku           String              @unique
  barcode       String?
  price         Decimal             @db.Decimal(12, 2)
  costPrice     Decimal             @map("cost_price") @db.Decimal(12, 2)
  attributes    Json
  createdAt     DateTime            @default(now()) @map("created_at")
  balances      InventoryBalance[]
  items         InvoiceItem[]
  product       Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseItems PurchaseOrderItem[]

  @@index([tenantId, sku])
  @@index([tenantId, barcode])
  @@map("product_variants")
  @@schema("tenant_data")
}

model Warehouse {
  id             String             @id @default(uuid()) @db.Uuid
  tenantId       String             @map("tenant_id") @db.Uuid
  name           String
  address        String?
  createdAt      DateTime           @default(now()) @map("created_at")
  balances       InventoryBalance[]
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@map("warehouses")
  @@schema("tenant_data")
}

model InventoryBalance {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @map("tenant_id") @db.Uuid
  warehouseId      String         @map("warehouse_id") @db.Uuid
  variantId        String         @map("variant_id") @db.Uuid
  quantity         Decimal        @default(0.000) @db.Decimal(12, 3)
  reservedQuantity Decimal        @default(0.000) @map("reserved_quantity") @db.Decimal(12, 3)
  reorderLevel     Decimal?       @default(10.000) @map("reorder_level") @db.Decimal(12, 3)
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, variantId])
  @@index([tenantId, warehouseId, variantId])
  @@map("inventory_balances")
  @@schema("tenant_data")
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  customerId    String?       @map("customer_id") @db.Uuid
  invoiceNumber String        @map("invoice_number")
  status        String
  subTotal      Decimal       @map("sub_total") @db.Decimal(12, 2)
  taxTotal      Decimal       @map("tax_total") @db.Decimal(12, 2)
  discountTotal Decimal       @default(0.00) @map("discount_total") @db.Decimal(12, 2)
  grandTotal    Decimal       @map("grand_total") @db.Decimal(12, 2)
  notes         String?
  issueDate     DateTime      @map("issue_date") @db.Date
  dueDate       DateTime      @map("due_date") @db.Date
  createdAt     DateTime      @default(now()) @map("created_at")
  items         InvoiceItem[]
  customer      Customer?     @relation(fields: [customerId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments      Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, issueDate])
  @@map("invoices")
  @@schema("tenant_data")
}

model InvoiceItem {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  invoiceId      String         @map("invoice_id") @db.Uuid
  variantId      String         @map("variant_id") @db.Uuid
  quantity       Decimal        @db.Decimal(12, 3)
  unitPrice      Decimal        @map("unit_price") @db.Decimal(12, 2)
  taxRate        Decimal        @default(15.00) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount      Decimal        @map("tax_amount") @db.Decimal(12, 2)
  discountAmount Decimal        @default(0.00) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount    Decimal        @map("total_amount") @db.Decimal(12, 2)
  invoice        Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variant        ProductVariant @relation(fields: [variantId], references: [id])

  @@map("invoice_items")
  @@schema("tenant_data")
}

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  category    String
  description String?
  expenseDate DateTime @map("expense_date") @db.Date
  receiptUrl  String?  @map("receipt_url")
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("expenses")
  @@schema("tenant_data")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  details   String?
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String   @map("ip_address")
  userAgent String   @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@schema("tenant_data")
}

model UserSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token")
  ipAddress    String   @map("ip_address")
  userAgent    String   @map("user_agent")
  isValid      Boolean  @default(true) @map("is_valid")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@map("user_sessions")
  @@schema("tenant_data")
}

model Invitation {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  email     String
  role      String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, email])
  @@map("invitations")
  @@schema("tenant_data")
}

model TenantModule {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  moduleId  String   @map("module_id")
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@map("tenant_modules")
  @@schema("tenant_data")
}

model Payment {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  invoiceId     String?  @map("invoice_id") @db.Uuid
  amount        Decimal  @db.Decimal(12, 2)
  paymentMethod String   @map("payment_method")
  status        String
  reference     String?
  paidAt        DateTime @default(now()) @map("paid_at")
  invoice       Invoice? @relation(fields: [invoiceId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId])
  @@map("payments")
  @@schema("tenant_data")
}

// ==========================================
// BUSINESS TEMPLATE REGISTRY MODELS (core_platform schema)
// ==========================================

model BusinessTemplate {
  id           String               @id @default(uuid()) @db.Uuid
  code         String               @unique
  name         String
  description  String?
  industryType String               @map("industry_type")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  modules      TemplateModule[]
  roles        TemplateRole[]
  dashboards   TemplateDashboard[]
  workflows    TemplateWorkflow[]
  tenants      TenantTemplate[]

  @@map("business_templates")
  @@schema("core_platform")
}

model TemplateModule {
  id          String           @id @default(uuid()) @db.Uuid
  templateId  String           @map("template_id") @db.Uuid
  moduleId    String           @map("module_id")
  isRequired  Boolean          @default(true) @map("is_required")
  template    BusinessTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, moduleId])
  @@map("template_modules")
  @@schema("core_platform")
}

model TemplateRole {
  id          String               @id @default(uuid()) @db.Uuid
  templateId  String               @map("template_id") @db.Uuid
  code        String
  name        String
  description String?
  template    BusinessTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  permissions TemplatePermission[]

  @@unique([templateId, code])
  @@map("template_roles")
  @@schema("core_platform")
}

model TemplatePermission {
  id             String       @id @default(uuid()) @db.Uuid
  templateRoleId String       @map("template_role_id") @db.Uuid
  module         String
  action         String
  role           TemplateRole @relation(fields: [templateRoleId], references: [id], onDelete: Cascade)

  @@map("template_permissions")
  @@schema("core_platform")
}

model TemplateDashboard {
  id         String           @id @default(uuid()) @db.Uuid
  templateId String           @map("template_id") @db.Uuid
  widgetCode String           @map("widget_code")
  widgetName String           @map("widget_name")
  gridPos    Json             @map("grid_position")
  template   BusinessTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_dashboards")
  @@schema("core_platform")
}

model TemplateWorkflow {
  id          String           @id @default(uuid()) @db.Uuid
  templateId  String           @map("template_id") @db.Uuid
  entityType  String           @map("entity_type")
  stateCode   String           @map("state_code")
  stateName   String           @map("state_name")
  sortOrder   Int              @map("sort_order")
  isInitial   Boolean          @default(false) @map("is_initial")
  isFinal     Boolean          @default(false) @map("is_final")
  template    BusinessTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_workflows")
  @@schema("core_platform")
}

model TenantTemplate {
  tenantId   String           @id @map("tenant_id") @db.Uuid
  templateId String           @map("template_id") @db.Uuid
  assignedAt DateTime         @default(now()) @map("assigned_at")
  template   BusinessTemplate @relation(fields: [templateId], references: [id])
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_templates")
  @@schema("core_platform")
}

// ==========================================
// TENANT CONFIGURATION MODELS (tenant_data schema)
// ==========================================

model TenantDashboardWidget {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  widgetCode String   @map("widget_code")
  widgetName String   @map("widget_name")
  gridPos    Json     @map("grid_position")
  isVisible  Boolean  @default(true) @map("is_visible")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@map("tenant_dashboard_widgets")
  @@schema("tenant_data")
}

model TenantWorkflowState {
  id         String          @id @default(uuid()) @db.Uuid
  tenantId   String          @map("tenant_id") @db.Uuid
  entityType String          @map("entity_type")
  stateCode  String          @map("state_code")
  stateName  String          @map("state_name")
  sortOrder  Int             @map("sort_order")
  isInitial  Boolean         @default(false) @map("is_initial")
  isFinal    Boolean         @default(false) @map("is_final")
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transitions TenantWorkflowTransition[] @relation("FromState")
  incomingTransitions TenantWorkflowTransition[] @relation("ToState")

  @@unique([tenantId, entityType, stateCode])
  @@map("tenant_workflow_states")
  @@schema("tenant_data")
}

model TenantWorkflowTransition {
  id          String              @id @default(uuid()) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  entityType  String              @map("entity_type")
  fromStateId String              @map("from_state_id") @db.Uuid
  toStateId   String              @map("to_state_id") @db.Uuid
  roleName    String?             @map("role_name")
  fromState   TenantWorkflowState @relation("FromState", fields: [fromStateId], references: [id], onDelete: Cascade)
  toState     TenantWorkflowState @relation("ToState", fields: [toStateId], references: [id], onDelete: Cascade)

  @@map("tenant_workflow_transitions")
  @@schema("tenant_data")
}

model Supplier {
  id             String          @id @default(uuid()) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  name           String
  email          String?
  phone          String?
  taxNumber      String?         @map("tax_number")
  address        String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@map("suppliers")
  @@schema("tenant_data")
}

model PurchaseOrder {
  id             String              @id @default(uuid()) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  supplierId     String              @map("supplier_id") @db.Uuid
  warehouseId    String              @map("warehouse_id") @db.Uuid
  orderNumber    String              @map("order_number")
  status         String              @default("DRAFT") // DRAFT, ORDERED, RECEIVED, CANCELLED
  subTotal       Decimal             @map("sub_total") @db.Decimal(12, 2)
  taxTotal       Decimal             @map("tax_total") @db.Decimal(12, 2)
  grandTotal     Decimal             @map("grand_total") @db.Decimal(12, 2)
  notes          String?
  issueDate      DateTime            @map("issue_date") @db.Date
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  items          PurchaseOrderItem[]
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse      Warehouse           @relation(fields: [warehouseId], references: [id])

  @@unique([tenantId, orderNumber])
  @@map("purchase_orders")
  @@schema("tenant_data")
}

model PurchaseOrderItem {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  purchaseOrderId String         @map("purchase_order_id") @db.Uuid
  variantId       String         @map("variant_id") @db.Uuid
  quantity        Decimal        @db.Decimal(12, 3)
  unitCost        Decimal        @map("unit_cost") @db.Decimal(12, 2)
  taxRate         Decimal        @default(15.00) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount       Decimal        @map("tax_amount") @db.Decimal(12, 2)
  totalAmount     Decimal        @map("total_amount") @db.Decimal(12, 2)
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  @@map("purchase_order_items")
  @@schema("tenant_data")
}

model Vehicle {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  customerId    String    @map("customer_id") @db.Uuid
  plateNumber   String    @map("plate_number")
  chassisNumber String?   @map("chassis_number")
  brand         String
  model         String
  year          Int?
  color         String?
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects      Project[]

  @@unique([tenantId, plateNumber])
  @@map("vehicles")
  @@schema("tenant_data")
}

model Project {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  vehicleId    String?   @map("vehicle_id") @db.Uuid
  name         String
  description  String?
  status       String    @default("LEAD") // Maps to workflow stateCode
  amount       Decimal   @default(0.00) @db.Decimal(12, 2)
  measurements Json?     // To store flexible custom dimensions
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  customer     Customer  @relation(fields: [customerId], references: [id])
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?  @relation(fields: [vehicleId], references: [id])
  tasks        Task[]

  @@map("projects")
  @@schema("tenant_data")
}

model Task {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  title       String
  description String?
  status      String    @default("TODO")
  dueDate     DateTime? @map("due_date") @db.Date
  assignedTo  String?   @map("assigned_to")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tasks")
  @@schema("tenant_data")
}

model ProductionOrder {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  productName    String   @map("product_name")
  rawMaterials   String   @map("raw_materials")
  quantity       Int      @default(0)
  machineName    String?  @map("machine_name")
  supervisorName String?  @map("supervisor_name")
  status         String   @default("RAW_MATERIALS") // Maps to workflow stateCode
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("production_orders")
  @@schema("tenant_data")
}
